# ──────────────────────────────────────────────
# MediPortal — Variabili d'ambiente
# Copia questo file in .env e compila i valori
# ──────────────────────────────────────────────

# Database MySQL
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/mediaportal"

# NextAuth
NEXTAUTH_SECRET="cambia-questo-valore-in-produzione"
NEXTAUTH_URL="http://localhost:3000"

# Upload referti (cartella locale in sviluppo)
UPLOAD_DIR="./public/uploads/referti"

# Ambiente
NODE_ENV="development"
